# Copy this file to .env.local for local development (never commit .env.local)

# Full URL of the backend — used by Socket.io only.
# In development this defaults to http://localhost:3001
# In production set this to your Render service URL, e.g.:
# VITE_BACKEND_URL=https://your-app.onrender.com
VITE_BACKEND_URL=http://localhost:3001
