# Copy this file to .env for local development (never commit .env)

# URL of the deployed frontend (e.g. https://your-app.netlify.app)
# In development this defaults to http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Admin panel password
# In development this defaults to 'admin123'
ADMIN_PASSWORD=change_me_in_production

# PORT is set automatically by Render; leave it unset locally to use 3001
# PORT=3001

# Optional: path to a specific Chromium/Chrome binary for Puppeteer
# On Render the bundled Chromium is used automatically
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
